<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ==================== 三级头盔 (Tier 3 Helmet) - 原生版 ==================== -->
  <!-- 完全对照 LWOP LWApparelArmorHelmetPowerBase 结构 -->

  <ThingDef ParentName="ApparelBase">
    <defName>MyMod_Tier3Helmet_Vanilla</defName>
    <label>Flying Tigers Elite Helmet (Vanilla)</label>
    <description>Elite combat helmet from the Flying Tigers unit. Provides exceptional protection against bullets, blunt attacks, and electrical damage. Enhanced with advanced materials for maximum defense. (Vanilla version)</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PowerArmorHelmet/PowerArmorHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <techLevel>Spacer</techLevel>
    <generateCommonality>0</generateCommonality>
    <uiIconScale>1.25</uiIconScale>

    <!-- statBases 对照 LWOP -->
    <statBases>
      <WorkToMake>60</WorkToMake>
      <MaxHitPoints>2500</MaxHitPoints>
      <Mass>0</Mass>
      <Flammability>0.0</Flammability>
      <ArmorRating_Sharp>999</ArmorRating_Sharp>
      <ArmorRating_Blunt>999</ArmorRating_Blunt>
      <ArmorRating_Heat>999</ArmorRating_Heat>
      <Insulation_Cold>999</Insulation_Cold>
      <Insulation_Heat>999</Insulation_Heat>
      <EquipDelay>0</EquipDelay>
    </statBases>

    <!-- equippedStatOffsets 对照 LWOP -->
    <equippedStatOffsets>
      <ResearchSpeedFactor>999999</ResearchSpeedFactor>
      <GlobalLearningFactor>999999</GlobalLearningFactor>
      <HackingSpeed>999999</HackingSpeed>
      <PruningSpeed>999999</PruningSpeed>
      <NegotiationAbility>100</NegotiationAbility>
      <TradePriceImprovement>100</TradePriceImprovement>
      <SocialImpact>100</SocialImpact>
      <ConversionPower>100</ConversionPower>
      <ArrestSuccessChance>100</ArrestSuccessChance>
      <SuppressionPower>100</SuppressionPower>
      <TameAnimalChance>100</TameAnimalChance>
      <TrainAnimalChance>100</TrainAnimalChance>
      <BondAnimalChanceFactor>100</BondAnimalChanceFactor>
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">100</VacuumResistance>
      <ToxicEnvironmentResistance MayRequire="Ludeon.RimWorld.Biotech">99</ToxicEnvironmentResistance>
      <PsychicEntropyRecoveryRate MayRequire="Ludeon.RimWorld.Royalty">9999</PsychicEntropyRecoveryRate>
      <MeditationFocusGain MayRequire="Ludeon.RimWorld.Royalty">9999</MeditationFocusGain>
      <PsychicEntropyGain MayRequire="Ludeon.RimWorld.Royalty">0.0001</PsychicEntropyGain>
      <PsychicEntropyMax MayRequire="Ludeon.RimWorld.Royalty">9999</PsychicEntropyMax>
    </equippedStatOffsets>

    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <tradeTags>
      <li>LWHiTechArmor</li>
    </tradeTags>
    <costList>
      <Steel>1</Steel>
    </costList>
    <apparel>
      <bodyPartGroups>
        <li>FullHead</li>
      </bodyPartGroups>
      <layers>
        <li>Overhead</li>
      </layers>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PowerArmorHelmet/PowerArmorHelmet</wornGraphicPath>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
    </apparel>

    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9,1)</only>
        </li>
      </options>
    </colorGenerator>

    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>

    <recipeMaker>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>0</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>FabricationBench</li>
        <li>TableMachining</li>
        <li>CraftingSpot</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>

</Defs>
