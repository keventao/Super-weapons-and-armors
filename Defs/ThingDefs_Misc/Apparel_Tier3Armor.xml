<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ==================== 三级护甲 (Tier 3 Armor) - 原生版 ==================== -->
  <!-- 完全对照 LWOP lwApparelArmorPowerBase 结构 -->

  <ThingDef ParentName="ApparelBase">
    <defName>MyMod_Tier3Armor_Vanilla</defName>
    <label>Flying Tigers Elite Armor (Vanilla)</label>
    <description>Elite combat armor from the Flying Tigers unit. Provides exceptional protection against bullets, blunt attacks, and electrical damage. Features superior mobility and environmental resistance. (Vanilla version)</description>
    <graphicData>
      <texPath>Things/Pawn/Humanlike/Apparel/PowerArmor/PowerArmor</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <techLevel>Spacer</techLevel>
    <generateCommonality>0</generateCommonality>

    <!-- statBases 对照 LWOP -->
    <statBases>
      <WorkToMake>60</WorkToMake>
      <MaxHitPoints>4000</MaxHitPoints>
      <Mass>1</Mass>
      <Flammability>0</Flammability>
      <ArmorRating_Sharp>999</ArmorRating_Sharp>
      <ArmorRating_Blunt>999</ArmorRating_Blunt>
      <ArmorRating_Heat>999</ArmorRating_Heat>
      <Insulation_Cold>999</Insulation_Cold>
      <Insulation_Heat>999</Insulation_Heat>
      <EquipDelay>0</EquipDelay>
      <JumpRange>999</JumpRange>
      <PackRadius>4.9</PackRadius>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>1</AccuracyMedium>
      <AccuracyLong>1</AccuracyLong>
      <RangedWeapon_Cooldown>0</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
    </statBases>

    <!-- equippedStatOffsets 对照 LWOP -->
    <equippedStatOffsets>
      <!-- Biotech 相关 -->
      <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">100</VacuumResistance>
      <ToxicEnvironmentResistance MayRequire="Ludeon.RimWorld.Biotech">100</ToxicEnvironmentResistance>
      <MechControlGroups MayRequire="Ludeon.RimWorld.Biotech">3</MechControlGroups>
      <MechBandwidth MayRequire="Ludeon.RimWorld.Biotech">100</MechBandwidth>
      <WorkSpeedGlobalOffsetMech MayRequire="Ludeon.RimWorld.Biotech">9999</WorkSpeedGlobalOffsetMech>
      <MechRemoteRepairDistance MayRequire="Ludeon.RimWorld.Biotech">9999</MechRemoteRepairDistance>
      <MechFormingSpeed MayRequire="Ludeon.RimWorld.Biotech">9999</MechFormingSpeed>
      <MechRemoteShieldDistance MayRequire="Ludeon.RimWorld.Biotech">9999</MechRemoteShieldDistance>
      <MechRemoteShieldEnergy MayRequire="Ludeon.RimWorld.Biotech">9999</MechRemoteShieldEnergy>
      <MechRepairSpeed MayRequire="Ludeon.RimWorld.Biotech">9999</MechRepairSpeed>
      <!-- Royalty 相关 -->
      <PsychicEntropyRecoveryRate MayRequire="Ludeon.RimWorld.Royalty">9999</PsychicEntropyRecoveryRate>
      <MeditationFocusGain MayRequire="Ludeon.RimWorld.Royalty">9999</MeditationFocusGain>
      <PsychicEntropyGain MayRequire="Ludeon.RimWorld.Royalty">0.0001</PsychicEntropyGain>
      <PsychicEntropyMax MayRequire="Ludeon.RimWorld.Royalty">9999</PsychicEntropyMax>
      <!-- 通用加成（对照 LWOP 的 30000，按原版比例调整） -->
      <MoveSpeed>300</MoveSpeed>
      <WorkSpeedGlobal>50</WorkSpeedGlobal>
      <CarryingCapacity>1000</CarryingCapacity>
    </equippedStatOffsets>

    <thingCategories>
      <li>ApparelArmor</li>
    </thingCategories>
    <tradeTags>
      <li>LWHiTechArmor</li>
    </tradeTags>
    <costList>
      <Steel>1</Steel>
    </costList>
    <apparel>
      <bodyPartGroups>
        <li>Torso</li>
        <li>Neck</li>
        <li>Shoulders</li>
        <li>Arms</li>
        <li>Legs</li>
        <li>Hands</li>
        <li>Feet</li>
      </bodyPartGroups>
      <layers>
        <li>Shell</li>
      </layers>
      <wornGraphicPath>Things/Pawn/Humanlike/Apparel/PowerArmor/PowerArmor</wornGraphicPath>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
    </apparel>

    <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(0.33,0.33,0.33,1)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.65,0.65,0.65,1)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(0.3,0.3,0.3,1)</min>
          <max>(0.5,0.5,0.5,1)</max>
        </li>
        <li>
          <weight>10</weight>
          <only>(0.9,0.9,0.9,1)</only>
        </li>
      </options>
    </colorGenerator>

    <thingSetMakerTags>
      <li>RewardStandardHighFreq</li>
    </thingSetMakerTags>

    <recipeMaker>
      <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>1</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="False">
        <li>FabricationBench</li>
        <li>TableMachining</li>
        <li>CraftingSpot</li>
      </recipeUsers>
    </recipeMaker>
  </ThingDef>

</Defs>
