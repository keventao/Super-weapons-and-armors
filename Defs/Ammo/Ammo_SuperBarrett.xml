<?xml version="1.0" encoding="UTF-8"?>
<Defs>
    <!-- ==================== Super Barrett Ammo ==================== -->
    
    <!-- Ammo Set -->
    <CombatExtended.AmmoSetDef>
        <defName>AmmoSet_SuperBarrett</defName>
        <label>Super Barrett</label>
        <ammoTypes>
            <Ammo_SuperBarrett>Bullet_SuperBarrett</Ammo_SuperBarrett>
        </ammoTypes>
    </CombatExtended.AmmoSetDef>

    <!-- Ammo Definition -->
    <ThingDef Class="CombatExtended.AmmoDef" Name="SuperBarrettAmmoBase" ParentName="MediumAmmoBase" Abstract="True">
        <description>Super Barrett ammunition - extremely powerful anti-materiel round.</description>
        <statBases>
            <Mass>0.1</Mass>
            <Bulk>0.01</Bulk>
        </statBases>
        <tradeTags>
            <li>CE_AutoEnableTrade</li>
            <li>CE_AutoEnableCrafting</li>
        </tradeTags>
        <thingCategories>
            <li>AmmoRifles</li>
        </thingCategories>
    </ThingDef>

    <ThingDef Class="CombatExtended.AmmoDef" ParentName="SuperBarrettAmmoBase">
        <defName>Ammo_SuperBarrett</defName>
        <label>Super Barrett cartridge</label>
        <description>Super Barrett ammunition - extremely powerful anti-materiel round.</description>
        <graphicData>
            <texPath>Things/Ammo/HighCaliber/FMJ</texPath>
            <graphicClass>Graphic_StackCount</graphicClass>
        </graphicData>
        <ammoClass>ArmorPiercing</ammoClass>
        <cookOffProjectile>Bullet_SuperBarrett</cookOffProjectile>
    </ThingDef>

    <!-- Projectile -->
    <ThingDef Name="BaseSuperBarrettBullet" ParentName="BaseBulletCE" Abstract="true">
        <graphicData>
            <texPath>Things/Projectile/Bullet_Big</texPath>
            <graphicClass>Graphic_Single</graphicClass>
        </graphicData>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageDef>Bullet</damageDef>
            <speed>200</speed>
            <dropsCasings>true</dropsCasings>
            <flyOverhead>false</flyOverhead>
        </projectile>
    </ThingDef>

    <ThingDef ParentName="BaseSuperBarrettBullet">
        <defName>Bullet_SuperBarrett</defName>
        <label>Super Barrett bullet</label>
        <projectile Class="CombatExtended.ProjectilePropertiesCE">
            <damageAmountBase>66</damageAmountBase>
            <armorPenetrationSharp>80</armorPenetrationSharp>
            <armorPenetrationBlunt>9</armorPenetrationBlunt>
            <speed>180</speed>
        </projectile>
    </ThingDef>

    <RecipeDef ParentName="AmmoRecipeBase">
        <defName>MakeAmmo_SuperBarrett</defName>
        <label>make Super Barrett cartridge x1000</label>
        <description>Craft 1000 Super Barrett cartridges.</description>
        <jobString>Making Super Barrett cartridges.</jobString>
        <ingredients>
            <li>
                <filter>
                    <thingDefs>
                        <li>Steel</li>
                    </thingDefs>
                </filter>
                <count>1</count>
            </li>
        </ingredients>
        <fixedIngredientFilter>
            <thingDefs>
                <li>Steel</li>
            </thingDefs>
        </fixedIngredientFilter>
        <products>
            <Ammo_SuperBarrett>1000</Ammo_SuperBarrett>
        </products>
        <workAmount>2000</workAmount>
    </RecipeDef>

</Defs>
